on \u003d \u0027\u0027\n\t\tself.view.custom.tagPath \u003d \u0027\u0027\n\n\t\t\n\t\tself.view.custom.devEUI\u003d \u0027\u0027\n\n\t\tself.view.custom.deviceName\u003d \u0027\u0027\n\t\tself.view.custom.imageUploaded \u003d False\n\t\tself.view.custom.image \u003d None\n\t\tself.meta.visible \u003d True\t\n\t\tsystem.perspective.navigate(page\u003d\"/mobileDeviceList\")\t\n\n\texcept Exception as e:\n\t\tsystem.perspective.print(e)\n\t\tsyncErrorMessage \u003d str(e)\n\t\tutils.messages.waiting.hideLoading()\n\t\tutils.messages.errors.showErrorMessage(syncErrorMessage)\n\t\tself.meta.visible \u003d True"
                  },
