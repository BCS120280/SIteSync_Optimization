              "style": {
                "backgroundColor": "#0D5C63",
                "borderBottomLeftRadius": "12px",
                "borderBottomRightRadius": "12px",
                "borderTopLeftRadius": "12px",
                "borderTopRightRadius": "12px",
                "classes": "formLabel",
                "color": "#FFFFFF",
                "fontSize": 16,
                "marginBottom": "10%"
              },
              "text": "Launch QR Scanner"
            },
            "scripts": {
              "customMethods": [],
              "extensionFunctions": null,
              "messageHandlers": [
                {
                  "messageType": "QRSync",
                  "pageScope": false,
                  "script": "\t# implement your handler here\n\tlogger \u003d system.util.getLogger(\u0027SiteSyncQRScan\u0027)\n\t\n\n\ttry:\n\t\tlogger.info(str(payload))\n\t\tscannedData \u003d payload[\u0027scanValue\u0027]\n\t\tresults \u003d utils.QRCodeParser.parse(scannedData)\n\t\tlogger.info(str(results))\n\t\t\n\t\n\t\tif results[\u0027devEUI\u0027] !\u003d \"\":\n\t\t\n\t\t\tfoundDevice \u003d system.sitesync.lookupDevice(results[\u0027devEUI\u0027])\n\t\t\t\n\t\t\tutils.messages.waiting.hideLoading()\n\t\t\tif foundDevice !\u003d None:\n\t\t\t\timport json\n\t\t\t\td \u003d json.loads(foundDevice)\n\t\t\t\tif self.session.custom.showQRAlreadySynced:\n\t\t\t\t\tsystem.perspective.navigate( view \u003d \"QRSync/alreadyRegisteredDialog\", params \u003d {\"device\":d, \"QRscan\":results})\n\t\t\t\t\n\t\t\t\telse:\n\t\t\t\t\tsystem.perspective.navigate( view \u003d \"QRSync/mobileActivation\", params \u003d {\"device\":d})\n\n\t\t\telse:\n\t\t\t\tsystem.perspective.navigate( view \u003d \"QRSync/mobileQRAdd\", params \u003d {\"qrScan\":results})\n\t\t\t\t\n\t\telse:\n\t\t\tsystem.perspective.navigate( view \u003d \"QRSync/mobileQRAdd\", params \u003d {\"qrScan\":results})\n\t\t\n\texcept Exception as e:\n\t\tlogger.info(str(e))",
                  "sessionScope": true,
                  "viewScope": false
                }
              ]
            },
            "type": "ia.input.button"
          },
          {
            "meta": {
              "name": "Label"
            },
