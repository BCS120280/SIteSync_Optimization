            "meta": {
              "name": "Button_launchQR"
            },
            "position": {
              "basis": "72px"
            },
            "propConfig": {
              "meta.visible": {
                "binding": {
                  "config": {
                    "expression": "({session.props.device.type} \u003d \"android\" || {session.props.device.type} \u003d \"ios\")"
                  },
                  "type": "expr"
                }
              },
              "props.enabled": {
                "binding": {
                  "config": {
                    "expression": "({session.props.device.type} \u003d \"android\" || {session.props.device.type} \u003d \"ios\")"
                  },
                  "type": "expr"
