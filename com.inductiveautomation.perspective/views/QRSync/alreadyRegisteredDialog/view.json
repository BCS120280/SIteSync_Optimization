{
  "custom": {},
  "params": {
    "QRscan": {
      "appKey": "appKey",
      "description": "",
      "devEUI": "devEUI",
      "deviceType": "",
      "joinEUI": "appEUI",
      "name": "",
      "scanType": "Vega"
    },
    "device": {
      "description": "value",
      "devEUI": "4150e4bd07bc81b1",
      "deviceName": "testetsttes",
      "deviceType": "value",
      "fullTagPath": "[default]hotdropTest1",
      "latitude": 0,
      "longitude": 0,
      "metaData": "value",
      "tagName": "testetsttes",
      "tagPathBase": "",
      "tagProvider": "default"
    }
  },
  "propConfig": {
    "params.QRscan": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.device": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "52px"
            },
            "props": {
              "path": "material/warning"
            },
            "type": "ia.display.icon"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "forms/configHeading",
                "textAlign": "center"
              },
              "text": "Device Already Registered in SiteSync"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "nameandEUI"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.device"
                  },
                  "transforms": [
                    {
                      "code": "\treturn self.view.params.device.deviceName + \" - \" + self.view.params.device.devEUI",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "padding": "2%",
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "devicetype"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.device.deviceType"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "padding": "2%",
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "description"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.device.description"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "padding": "2%",
                "textAlign": "center"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "style": {
            "classes": "forms/configurationBox"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "params": {
                      "qrScan": "{view.params.QRscan}"
                    },
                    "view": "QRSync/mobileQRAdd"
                  },
                  "scope": "C",
                  "type": "nav"
                }
              }
            },
            "meta": {
              "name": "SyncAgain"
            },
            "position": {
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "image": {
                "icon": {
                  "path": "material/refresh"
                }
              },
              "style": {
                "backgroundColor": "#80808078",
                "borderBottomLeftRadius": "12px",
                "borderBottomRightRadius": "12px",
                "borderTopLeftRadius": "12px",
                "borderTopRightRadius": "12px",
                "margin": "12%",
                "padding": "4%"
              },
              "text": "Sync Again"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "params": {
                      "device": "{view.params.device}"
                    },
                    "view": "QRSync/mobileActivation"
                  },
                  "scope": "C",
                  "type": "nav"
                }
              }
            },
            "meta": {
              "name": "update"
            },
            "position": {
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "image": {
                "icon": {
                  "path": "material/system_update"
                }
              },
              "style": {
                "backgroundColor": "teal",
                "borderBottomLeftRadius": "12px",
                "borderBottomRightRadius": "12px",
                "borderTopLeftRadius": "12px",
                "borderTopRightRadius": "12px",
                "margin": "12%",
                "padding": "4%"
              },
              "text": "Update Registration"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "options"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "justify": "space-evenly"
    },
    "type": "ia.container.flex"
  }
}