{
  "custom": {},
  "params": {
    "sensorType": "VALVEPOSITION",
    "sensors": {
      "VALVEPOSITION": [
        []
      ],
      "VIBRATION": [
        []
      ]
    }
  },
  "propConfig": {
    "params.sensorType": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.sensors": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.sensorType"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "/root.custom.tagPaths"
                  },
                  "transforms": [
                    {
                      "code": "\treturn \"(\" + str(len(value)) + \")\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "basis": "32px"
        },
        "props": {
          "style": {
            "borderBottomColor": "#4A2D2D6B",
            "borderBottomStyle": "solid",
            "margin": "2%"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "basis": "730px"
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "parent.custom.tagPaths"
              },
              "transforms": [
                {
                  "code": "\titems \u003d []\n\tfor d in value:\n\t\n\t\tj \u003d {\n\t  \"instanceStyle\": {\n\t    \"classes\": \"\"\n\t  },\n\t  \"instancePosition\": {},\n\t  \"tagPath\": d, \n\t  \"sensorType\":self.view.params.sensorType\n\t}\n\t\n\t\titems.append(j)\n\t\n\treturn items\n\t",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.path": {
            "binding": {
              "config": {
                "path": "view.params.sensorType"
              },
              "enabled": false,
              "transforms": [
                {
                  "code": "\tif value in (\"TEMPERATURE\", \"PRESSURE\", \"420ma\", \"FLOWMETER\"):\n\t\treturn \"Dashboard/components/assets/Temperature\"\n\telif value \u003d\u003d \"VALVEPOSITION\":\n\t\treturn \"Dashboard/components/assets/ValvePosition\"\n\t\t\n\telif value \u003d\u003d \"LEVEL\":\n\t\treturn \"Dashboard/components/assets/Level\"\n\telif value \u003d\u003d \"THL\":\n\t\treturn \"Dashboard/components/assets/THL\"\n\t\t\n\telif value \u003d\u003d \"HOTDROP\":\n\t\treturn \"Dashboard/components/assets/Current\"\n\t\t\n\telif value \u003d\u003d \"VIBRATION\":\n\t\treturn \"Dashboard/components/assets/Vibration\"\n\t\t\n\telif value \u003d\u003d \"LOCKOUT\":\n\t\treturn \"Dashboard/components/assets/Lockout\"\n\t\n\telse:\n\t\n\t\treturn \"Dashboard/components/assets/OtherPV\"",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "path": "Dashboard/components/assets/assetWrapper",
          "wrap": "wrap"
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "custom.tagPaths": {
        "binding": {
          "config": {
            "path": "view.params.sensorType"
          },
          "transforms": [
            {
              "code": "\tif value in self.view.params.sensors.keys():\n\t\treturn self.view.params.sensors[value]\n\telse:\n\t\treturn []",
              "type": "script"
            }
          ],
          "type": "property"
        }
      }
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}