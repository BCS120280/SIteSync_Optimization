{
  "custom": {},
  "params": {
    "tagPath": "default"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 100,
      "width": 200
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif \u0027/\u0027 in self.view.params.tagPath:\n\t\tsystem.perspective.sendMessage(\"removePath\", payload\u003d{\"tagPath\":self.view.params.tagPath.rsplit(\u0027/\u0027, 1)[0]})\n\telse:\n\t\tsystem.perspective.sendMessage(\"removePath\", payload\u003d{\"tagPath\":\"{0}]\".format(self.view.params.tagPath.split(\u0027]\u0027)[0])})"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "30px"
        },
        "props": {
          "path": "material/keyboard_backspace"
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Dropdown"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.options": {
            "binding": {
              "config": {
                "path": "parent.custom.options"
              },
              "type": "property"
            }
          },
          "props.placeholder.text": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "type": "property"
            }
          },
          "props.value": {
            "onChange": {
              "enabled": null,
              "script": "\tif currentValue.value !\u003d None:\n\t\tsystem.perspective.sendMessage(\"UpdatePath\", payload\u003d{\"tagPath\":currentValue.value})\n\telse:\n\t\tsystem.perspective.sendMessage(\"removePath\", payload\u003d{\"tagPath\":currentValue.value.rsplit(\u0027/\u0027, 1)[0]})"
            }
          }
        },
        "props": {
          "placeholder": {},
          "showClearIcon": true
        },
        "type": "ia.input.dropdown"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "custom.options": {
        "binding": {
          "config": {
            "path": "view.params.tagPath"
          },
          "transforms": [
            {
              "code": "\toptions \u003d []\n\tsystem.perspective.print(\"Initalizing folder structure {0}\".format(value))\n\ttry:\n\t\tresults \u003d system.tag.browse(value, {\"recursive\":False, \"tagType\":\"Folder\"}).results\n\t\tfor result in results:\n\t\t\tif \"_types_\" not in str(result[\u0027fullPath\u0027]):\n\t\t\t\toptions.append({\"value\":str(result[\u0027fullPath\u0027]), \"label\":str(result[\u0027fullPath\u0027]).split(\u0027/\u0027)[-1]})\n\texcept Exception as e:\n\t\tsystem.perspective.print(\"Error with sub folder listed\")\n\t\tsystem.perspective.print(e)\n\treturn options",
              "type": "script"
            }
          ],
          "type": "property"
        }
      }
    },
    "type": "ia.container.flex"
  }
}