{
  "custom": {},
  "params": {
    "tagPath": "[default]AloxyValvePosition"
  },
  "propConfig": {
    "params.engUnits": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.maxAnalogValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.minAnalogValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.processValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    },
    "dropConfig": {
      "udts": [
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/TE-Pressure"
        },
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/SushiPressure"
        },
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/TWTG-Pressure"
        }
      ]
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Tag Name"
        },
        "position": {
          "basis": "32px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\ttagName \u003d value.split(\u0027]\u0027)[1].split(\u0027/\u0027)[-1]\n\treturn tagName",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Dashboard/boldLabel"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Process Value Gauge"
        },
        "propConfig": {
          "props.label.units": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}/metaData/valueToDisplay"
              },
              "transforms": [
                {
                  "code": "\tif quality.isBadOrError():\n\t\treturn \"\"\n\telse:\n\t\treturn value",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          },
          "props.maxValue": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}/metaData/configuration.engHigh"
              },
              "transforms": [
                {
                  "code": "\tif quality.badOrError:\n\t\treturn 100\n\telse:\n\t\treturn value\n",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          },
          "props.minValue": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}/metaData/configuration.engLow"
              },
              "transforms": [
                {
                  "code": "\tif quality.badOrError:\n\t\treturn 0\n\telse:\n\t\treturn value",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}/metaData/valueToDisplay"
              },
              "transforms": [
                {
                  "code": "\tif quality.badOrError:\n\t\treturn -1\n\telse:\n\t\treturn value",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          }
        },
        "props": {
          "arc": {
            "color": "#0D5C63"
          },
          "arcBackground": {
            "color": "#83c5be"
          },
          "label": {
            "color": "#000000",
            "maxDecimal": 2,
            "size": 16
          },
          "style": {
            "classes": [],
            "color": "#2B2B2B",
            "fontFamily": "Roboto",
            "fontSize": "18px",
            "fontWeight": "bold"
          }
        },
        "type": "ia.chart.simple-gauge"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "justify": "center",
      "style": {
        "classes": "Dashboard/PVTile"
      }
    },
    "type": "ia.container.flex"
  }
}