        "propConfig": {
          "custom.historical[0].path": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\treturn value + \"/temperature\"",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "backgroundColor": "#FFFFFF",
            "classes": "Dashboard/PVTile"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "display": false,
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "Dashboard/boldLabel"
              },
              "text": "Last Event"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "Labelcurrent_1"
                    },
                    "position": {
                      "grow": 1
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "fallbackDelay": 2.5,
                            "mode": "indirect",
                            "references": {
                              "tagPath": "{view.params.tagPath}"
                            },
                            "tagPath": "{tagPath}/metaData/valueToDisplay.timestamp"
                          },
                          "transforms": [
                            {
                              "code": "\treturn utils.timeFormatter.time_elapsed_since_dateTag(value)",
                              "type": "script"
                            }
                          ],
                          "type": "tag"
                        }
                      }
                    },
                    "props": {
                      "textStyle": {
                        "classes": "Dashboard/label"
                      }
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "FlexContainer"
                },
                "position": {
                  "grow": 1,
                  "shrink": 0
                },
                "props": {
                  "direction": "column"
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "props": {
              "direction": "column"
            },
            "type": "ia.container.flex"
          }
        ],
        "custom": {
          "historical": [
            {
              "aggregation": "Average",
              "alias": "Humidity"
            }
          ]
        },
        "meta": {
          "name": "tempContainer_0"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "custom.historical[0].path": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\treturn value + \"/humidity\"",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "backgroundColor": "#FFFFFF",
            "classes": "Dashboard/PVTile"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "backgroundColor": "#FFFFFF",
        "classes": "Dashboard/PVTile"
      }
    },
    "type": "ia.container.flex"
  }
}