{
  "custom": {},
  "params": {
    "tagPath": "[default]THL-F286"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    },
    "dropConfig": {
      "udts": [
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/THL"
        }
      ]
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "tempReading"
        },
        "position": {
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\treturn value.split(\u0027]\u0027)[1].split(\u0027/\u0027)[-1]",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Dashboard/boldLabel"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "grow": 1,
              "shrink": 0
            },
            "props": {
              "style": {
                "classes": "Dashboard/boldLabel"
              },
              "text": "Status"
            },
            "type": "ia.display.label"
          },
          {
            "children": [
              {
                "children": [
                  {
                    "meta": {
                      "name": "Labelcurrent_1"
                    },
                    "position": {
                      "grow": 1
                    },
                    "propConfig": {
                      "props.text": {
                        "binding": {
                          "config": {
                            "fallbackDelay": 2.5,
                            "mode": "indirect",
                            "references": {
                              "tagPath": "{view.params.tagPath}"
                            },
                            "tagPath": "{tagPath}/metaData/valueToDisplay"
                          },
                          "type": "tag"
                        }
                      }
                    },
                    "props": {
                      "textStyle": {
                        "classes": "Dashboard/label"
                      }
                    },
                    "type": "ia.display.label"
                  }
                ],
                "meta": {
                  "name": "FlexContainer"
                },
                "position": {
                  "grow": 1,
                  "shrink": 0
                },
                "props": {
                  "direction": "column"
                },
                "type": "ia.container.flex"
              }
            ],
            "meta": {
              "name": "FlexContainer"
            },
            "position": {
              "basis": "112.5px"
            },
            "type": "ia.container.flex"
          }
        ],
        "custom": {
          "historical": [
            {
              "aggregation": "Average",
              "alias": "Temperature"
            }
          ]
        },
        "meta": {
          "name": "tempContainer"
        },
        "position": {
          "grow": 1,
          "shrink": 0
