{
  "custom": {},
  "params": {
    "tagPath": "[default]AloxyValvePosition"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    },
    "dropConfig": {
      "udts": [
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/AloxyValvePosition"
        }
      ]
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Tag Name"
        },
        "position": {
          "basis": "32px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\ttagName \u003d value.split(\u0027]\u0027)[1].split(\u0027/\u0027)[-1]\n\treturn tagName",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Dashboard/boldLabel"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Tag Name_0"
            },
            "position": {
              "grow": 1,
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}/metaData/valueToDisplay"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "Dashboard/boldLabel"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Tag Name"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}/metaData/valueToDisplay.engUnit"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "Dashboard/boldLabel"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "basis": "32px"
        },
        "props": {
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "justify": "space-around",
      "style": {
        "classes": "Dashboard/PVTile"
      }
    },
    "type": "ia.container.flex"
  }
}