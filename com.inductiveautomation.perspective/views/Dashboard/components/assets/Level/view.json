{
  "custom": {},
  "params": {
    "tagPath": "[default]BourdonPressureGauge-03D5"
  },
  "propConfig": {
    "params.engUnits": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.maxAnalogValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.minAnalogValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.processValue": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 250,
      "width": 250
    },
    "dropConfig": {
      "udts": [
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/TE-Pressure"
        },
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/SushiPressure"
        },
        {
          "action": "path",
          "param": "tagPath",
          "type": "SiteSync/TWTG-Pressure"
        }
      ]
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Tag Name"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\ttagName \u003d value.split(\u0027]\u0027)[1].split(\u0027/\u0027)[-1]\n\treturn tagName",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "Dashboard/boldLabel"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "CylindricalTank"
        },
        "position": {
          "basis": "154px"
        },
        "propConfig": {
          "props.capacity": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}/metaData/configuration.engHigh"
              },
              "type": "tag"
            }
          },
          "props.value": {
            "binding": {
              "config": {
                "path": "parent.custom.currValue"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "margin": "10%"
          }
        },
        "type": "ia.display.cylindrical-tank"
      },
      {
        "children": [
          {
            "meta": {
              "deviceUDT": "Process Value",
              "name": "PV Value Display"
            },
            "position": {
              "basis": "55px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "/root.custom.currValue"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "Dashboard/boldLabel"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "deviceUDT": "Process Value",
              "name": "Engineering Units"
            },
            "position": {
              "basis": "20px",
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}/metaData/valueToDisplay.engUnit"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "classes": "Dashboard/label"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "deviceUDT": "Process Value Numeric",
          "name": "PV Value Display Container"
        },
        "position": {
          "basis": 25,
          "shrink": 0
        },
        "props": {
          "justify": "center",
          "style": {
            "marginBottom": 3,
            "marginTop": 0
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "custom.arcColor": {
        "binding": {
          "config": {
            "expression": "if({this.custom.currValue} \u003e {this.custom.engLow} \u0026\u0026 {this.custom.currValue} \u003c {this.custom.engHigh}, \"#0D5C63\", \"#FF0004\")"
          },
          "type": "expr"
        }
      },
      "custom.currValue": {
        "binding": {
          "config": {
            "fallbackDelay": 2.5,
            "mode": "indirect",
            "references": {
              "tagPath": "{view.params.tagPath}"
            },
            "tagPath": "{tagPath}/metaData/valueToDisplay"
          },
          "transforms": [
            {
              "code": "\tif quality.badOrError:\n\t\treturn -1\n\telse:\n\t\treturn float(value)",
              "type": "script"
            }
          ],
          "type": "tag"
        }
      },
      "custom.engHigh": {
        "binding": {
          "config": {
            "fallbackDelay": 2.5,
            "mode": "indirect",
            "references": {
              "tagPath": "{view.params.tagPath}"
            },
            "tagPath": "{tagPath}/metaData/valueToDisplay.engHigh"
          },
          "transforms": [
            {
              "code": "\tif quality.badOrError:\n\t\treturn -1\n\telse:\n\t\treturn value",
              "type": "script"
            }
          ],
          "type": "tag"
        }
      },
      "custom.engLow": {
        "binding": {
          "config": {
            "fallbackDelay": 2.5,
            "mode": "indirect",
            "references": {
              "tagPath": ""
            },
            "tagPath": "{tagPath}/metaData/valueToDisplay.engLow"
          },
          "transforms": [
            {
              "code": "\tif quality.badOrError:\n\t\treturn -1\n\telse:\n\t\treturn value",
              "type": "script"
            }
          ],
          "type": "tag"
        }
      }
    },
    "props": {
      "direction": "column",
      "justify": "center",
      "style": {
        "classes": "Dashboard/PVTile"
      }
    },
    "type": "ia.container.flex"
  }
}