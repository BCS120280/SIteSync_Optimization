{
  "custom": {},
  "params": {
    "icon": "material/insert_emoticon",
    "menuItem": "value",
    "message": "ALL"
  },
  "propConfig": {
    "params.icon": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.menuItem": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.message": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 80,
      "width": 200
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "30px",
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.path": {
            "binding": {
              "config": {
                "path": "view.params.icon"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "color": "#FFFFFF"
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "90%",
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.menuItem"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "marginLeft": "3%"
          },
          "textStyle": {
            "color": "#FFFFFF",
            "fontFamily": "Arial"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tparams \u003d {\"view\":self.view.params.message}\n\tsystem.perspective.sendMessage(\"changeView\", payload\u003dparams)"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "Dashboard/PVTile Dashboard/SiteSync",
        "overflow": "hidden"
      }
    },
    "type": "ia.container.flex"
  }
}