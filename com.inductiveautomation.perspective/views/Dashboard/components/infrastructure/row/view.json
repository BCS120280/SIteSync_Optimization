{
  "custom": {},
  "params": {
    "DeviceTypes": "VALVEPOSITION",
    "devicePaths": [
      "[default]AloxyValvePosition"
    ]
  },
  "propConfig": {
    "params.DeviceTypes": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.devicePaths": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 400
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.DeviceTypes"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "basis": "34px",
              "grow": 1
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.devicePaths"
                  },
                  "transforms": [
                    {
                      "code": "\treturn \"(\" + str(len(value)) + \")\"",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              }
            },
            "type": "ia.display.label"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tp \u003d {\"view\":self.view.params.DeviceTypes}\n\tsystem.perspective.sendMessage(\"changeView\", payload\u003dp)"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Icon",
              "tooltip": {
                "enabled": true,
                "text": "Click to view in new tab"
              }
            },
            "position": {
              "basis": "30px"
            },
            "props": {
              "path": "material/launch"
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "basis": "40px"
        },
        "props": {
          "style": {
            "borderBottomColor": "#4A2D2D6B",
            "borderBottomStyle": "solid",
            "margin": "2%"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.devicePaths"
              },
              "transforms": [
                {
                  "code": "\titems \u003d []\n\tfor d in value:\n\t\n\t\tj \u003d {\n\t  \"instanceStyle\": {\n\t    \"classes\": \"\"\n\t  },\n\t  \"instancePosition\": {},\n\t  \"tagPath\": d, \n\t  \"sensorType\":self.view.params.DeviceTypes\n\t}\n\t\n\t\titems.append(j)\n\t\n\treturn items\n\t",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.path": {
            "binding": {
              "config": {
                "path": "view.params.DeviceTypes"
              },
              "enabled": false,
              "transforms": [
                {
                  "code": "\tif value in (\"TEMPERATURE\", \"PRESSURE\", \"420ma\", \"FLOWMETER\"):\n\t\treturn \"Dashboard/components/assets/Temperature\"\n\telif value \u003d\u003d \"VALVEPOSITION\":\n\t\treturn \"Dashboard/components/assets/ValvePosition\"\n\t\t\n\telif value \u003d\u003d \"LEVEL\":\n\t\treturn \"Dashboard/components/assets/Level\"\n\telif value \u003d\u003d \"THL\":\n\t\treturn \"Dashboard/components/assets/THL\"\n\t\t\n\telif value \u003d\u003d \"HOTDROP\":\n\t\treturn \"Dashboard/components/assets/Current\"\n\t\t\n\telif value \u003d\u003d \"VIBRATION\":\n\t\treturn \"Dashboard/components/assets/Vibration\"\n\t\t\n\telif value \u003d\u003d \"LOCKOUT\":\n\t\treturn \"Dashboard/components/assets/Lockout\"\n\t\n\telse:\n\t\n\t\treturn \"Dashboard/components/assets/OtherPV\"",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "elementPosition": {
            "shrink": 0
          },
          "path": "Dashboard/components/assets/assetWrapper"
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}