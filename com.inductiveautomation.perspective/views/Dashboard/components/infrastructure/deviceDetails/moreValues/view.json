{
  "custom": {},
  "params": {
    "tagPath": "[default]aloxyCoreTest"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "id": "moreDetails",
                    "type": "close"
                  },
                  "scope": "C",
                  "type": "dock"
                }
              }
            },
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "30px"
            },
            "props": {
              "color": "#FFFFFF",
              "path": "material/close"
            },
            "type": "ia.display.icon"
          },
          {
            "meta": {
              "name": "Label"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.tagPath"
                  },
                  "transforms": [
                    {
                      "code": "\treturn value.split(\u0027]\u0027)[1].split(\u0027/\u0027)[-1]",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "color": "#FFFFFF",
                "fontFamily": "Arial",
                "fontWeight": "bold",
                "marginLeft": "3%"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "header"
        },
        "position": {
          "basis": "80px"
        },
        "props": {
          "style": {
            "classes": "Dashboard/SiteSync"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "values"
        },
        "props": {
          "path": "Dashboard/components/infrastructure/deviceDetails/moreDetails"
        },
        "type": "ia.display.view"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              },
              "text": "Configure Limits"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "headerLimits"
        },
        "position": {
          "basis": "32px"
        },
        "props": {
          "style": {
            "borderBottomColor": "#4A2D2D6B",
            "borderBottomStyle": "solid",
            "margin": "2%",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "limits"
        },
        "propConfig": {
          "props.params.tagPath": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "path": "Dashboard/components/infrastructure/deviceDetails/editLimits",
          "useDefaultViewHeight": true
        },
        "type": "ia.display.view"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}