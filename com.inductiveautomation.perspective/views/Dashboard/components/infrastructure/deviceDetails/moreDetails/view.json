{
  "custom": {},
  "params": {
    "tagPath": "value"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "grow": 1
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              },
              "text": "More Values"
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "headerLimits"
        },
        "position": {
          "basis": "32px"
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "../FlexRepeater.props.instances"
              },
              "transforms": [
                {
                  "code": "\tif len(value) \u003e 0 :\n\t\treturn True\n\telse:\n\t\treturn False",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "borderBottomColor": "#4A2D2D6B",
            "borderBottomStyle": "solid",
            "margin": "2%",
            "overflow": "hidden"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "propConfig": {
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.params.tagPath"
              },
              "transforms": [
                {
                  "code": "\ttagPath \u003d value + \"/displayValues\"\n\ttry:\n\t\ttags \u003d system.tag.browseTags(parentPath\u003dtagPath)\n\t\tinstances \u003d []\n\t\tfor tag in tags:\n\t\t\tj \u003d {\n\t\t\t  \"instanceStyle\": {\n\t\t\t    \"classes\": \"\"\n\t\t\t  },\n\t\t\t  \"instancePosition\": {},\n\t\t\t  \"tagPath\": tag.fullPath\n\t\t\t}\n\t\t\tinstances.append(j)\n\t\treturn instances\n\texcept:\n\t\treturn []",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "elementPosition": {
            "basis": "auto",
            "grow": 0,
            "shrink": 0
          },
          "path": "Devices/Details/values/displayRow",
          "useDefaultViewWidth": false
        },
        "type": "ia.display.flex-repeater"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}