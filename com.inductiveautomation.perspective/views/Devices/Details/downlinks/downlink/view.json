                "onClick": {
                  "config": {
                    "script": "\tself.props.enabled \u003d False\n\tutils.messages.waiting.showLoading()\n\ttry:\n\t\tresults \u003d decoders.downlinks.sendDownlink(self.view.params.hexCode, self.view.params.port, self.view.params.devEUI, enterprise.tenant.getDefaultApp())\n\t\tutils.messages.waiting.hideLoading()\n\t\tif utils.resultParser.isResultSuccess(results):\n\t\t\tutils.messages.success.showSuccess(\"Downlink sent to device\")\n\t\t\tdevice.tagOperations.updateTagValues([self.view.params.tagPath + \"/metaData/configuration\"], [self.view.params.description])\n\t\telse:\n\t\t\tutils.messages.errors.showErrorMessage(utils.resultParser.getResultMessage(results))\n\texcept Exception as e:\n\t\tutils.messages.waiting.hideLoading()\n\t\tutils.messages.errors.showErrorMessage(str(e))\n\tself.props.enabled \u003d True"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
