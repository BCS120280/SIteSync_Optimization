{
  "custom": {
    "downlinks": []
  },
  "params": {
    "devEUI": "value",
    "deviceProfileID": 26,
    "deviceProfileName": "",
    "tagPath": "value"
  },
  "propConfig": {
    "custom.downlinks": {
      "binding": {
        "config": {
          "path": "view.params.deviceProfileID"
        },
        "transforms": [
          {
            "code": "\tdownlinks \u003d []\n\tdwn \u003d decoders.downlinks.listDownlinks(int(value))\n\tif dwn !\u003d None:\n\t\tfor d in dwn:\n\t\t\tj \u003d {\n\t\t\t  \"instanceStyle\": {\n\t\t\t    \"classes\": \"\"\n\t\t\t  },\n\t\t\t  \"instancePosition\": {},\n\t\t\t  \"description\":d[\u0027description\u0027],\n\t\t\t  \"devEUI\": self.params.devEUI,\n\t\t\t  \"hexCode\": d[\u0027hexCommand\u0027],\n\t\t\t  \"name\": d[\u0027name\u0027],\n\t\t\t  \"port\": d[\u0027port\u0027], \n\t\t\t  \"tagPath\":self.params.tagPath\n\t\t\t}\n\t\t\tdownlinks.append(j)\n\treturn downlinks",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.devEUI": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.deviceProfileID": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.deviceProfileName": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label"
        },
        "props": {
          "text": "Downlinks are a way to send configuration commands to a LoRaWAN device. If downlinks are provisioned for this device\u0027s profile then commands will be available to send to the device."
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "props": {
              "text": "Current Configuration:",
              "textStyle": {
                "color": "#0D5C63",
                "fontSize": 20,
                "fontWeight": "bolder",
                "textAlign": "start"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "grow": 1,
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}/metaData/configuration"
                  },
                  "transforms": [
                    {
                      "code": "\tif quality.badOrError:\n\t\treturn \"Error getting current configuration\"\n\telif value \u003d\u003d None:\n\t\treturn \"Standard configuration\"\n\telse:\n\t\treturn value",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "3%"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "style": {
            "marginTop": "2%"
          }
        },
        "type": "ia.container.flex"
      },
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "position": {
          "grow": 1
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "view.custom.downlinks"
              },
              "transforms": [
                {
                  "code": "\treturn len(value) \u003e 0",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.instances": {
            "binding": {
              "config": {
                "path": "view.custom.downlinks"
              },
              "transforms": [
                {
                  "code": "\tif quality.badOrError:\n\t\treturn []\n\telse:\n\t\treturn value",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "direction": "column",
          "path": "Devices/Details/downlinks/downlinks",
          "style": {
            "marginTop": "2%"
          },
          "useDefaultViewWidth": false,
          "wrap": "wrap"
        },
        "type": "ia.display.flex-repeater"
      },
      {
        "meta": {
          "name": "noDownlinksFound"
        },
        "propConfig": {
          "position.display": {
            "binding": {
              "config": {
                "path": "view.custom.downlinks"
              },
              "transforms": [
                {
                  "code": "\treturn len(value) \u003d\u003d 0",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          },
          "props.params.deviceProfileID": {
            "binding": {
              "config": {
                "path": "view.params.deviceProfileID"
              },
              "type": "property"
            }
          },
          "props.params.deviceProfileName": {
            "binding": {
              "config": {
                "path": "view.params.deviceProfileName"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "path": "Devices/Details/components/noDownlinksFound"
        },
        "type": "ia.display.view"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "style": {
        "classes": "pageFormat/rootPadding"
      }
    },
    "type": "ia.container.flex"
  }
}