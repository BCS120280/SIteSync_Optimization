                "onClick": {
                  "config": {
                    "script": "\tmetaName \u003d self.getSibling(\"TextField\").props.text\n\tif metaName !\u003d None and len(metaName) \u003e 1:\n\t\tj \u003d {\n\t\t      \"instanceStyle\": {\n\t\t        \"classes\": \"\"\n\t\t      },\n\t\t      \"instancePosition\": {},\n\t\t      \"componentValue\": \"\",\n\t\t      \"isEditing\": True,\n\t\t      \"labelText\": metaName\n\t\t    }\n\t\t \n\t\tself.view.custom.items.append(j)\n\t\tself.getSibling(\"TextField\").props.text \u003d \"\"\n\t"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Icon",
              "tooltip": {
                "enabled": true,
                "text": "click to add metadata about your device"
              }
            },
