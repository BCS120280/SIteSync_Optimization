    "custom.items": {
      "binding": {
        "config": {
          "path": "view.params.isEditing"
        },
        "transforms": [
          {
            "code": "\tinstances \u003d []  # variable can be called anything, as long as the return variable name matches; I just like to have my variable names match what I\u0027m expecting back\n\ttry:\n\t\tif self.params.metaData !\u003d None:\n\t\t\tfor entry, val in self.params.metaData.items():\n\t\t\t    instance \u003d {\n\t\t\t      \"instanceStyle\": {\n\t\t\t        \"classes\": \"\"\n\t\t\t      },\n\t\t\t      \"instancePosition\": {},\n\t\t\t      \"componentValue\": val,\n\t\t\t      \"isEditing\": value,\n\t\t\t      \"labelText\": entry\n\t\t\t    }\n\t\t\t  \n\t\t\t    instances.append(instance)\n\t\treturn instances\n\texcept:\n\t\t\n\t\treturn instances\n\treturn value",
            "type": "script"
          }
        ],
        "type": "property"
      },
      "persistent": true
    },
    "params.isEditing": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.metaData": {
      "paramDirection": "input",
      "persistent": true
    }
  },
