    "props": {
      "direction": "column"
    },
    "scripts": {
      "customMethods": [],
      "extensionFunctions": null,
      "messageHandlers": [
        {
          "messageType": "getMetaData",
          "pageScope": true,
          "script": "\t# implement your handler here\n\tsystem.perspective.print(\"starting meta load\")\n\ttry:\n\t\tdevEUI \u003d payload[\u0027devEUI\u0027]\n\t\ttagPath \u003d payload[\u0027fullTagPath\u0027]\n\t\tmeta \u003d {}\n\t\tfor i in self.getChild(\"FlexRepeater\").props.instances:\n\t\t\tsystem.perspective.print(i)\n\t\t\tmeta[i[\u0027labelText\u0027]] \u003d i[\u0027componentValue\u0027]\n\t\tsystem.perspective.print(meta)\t\t\n\t\tif len(meta.keys()) \u003e 0:\n\t\t\timport json\n\t\t\t\t\t\n\t\t\tj \u003d json.dumps(meta)\n\t\t\tupdateMetaData \u003d device.tagOperations.updateMetaData(tagPath, j)\n\t\t\tdevice.updateDevice.updateDeviceMetaData(meta, devEUI)\n\texcept Exception as e:\n\t\tsystem.perspective.print(\"getMeta: \" + str(e))",
          "sessionScope": false,
          "viewScope": false
        }
      ]
    },
    "type": "ia.container.flex"
  }
