{
  "custom": {},
  "params": {
    "deviceProfileID": 12,
    "deviceProfileName": "te"
  },
  "propConfig": {
    "params.deviceProfileID": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.deviceProfileName": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "meta": {
          "name": "Icon"
        },
        "position": {
          "basis": "30px"
        },
        "props": {
          "path": "material/offline_bolt"
        },
        "type": "ia.display.icon"
      },
      {
        "meta": {
          "name": "Label"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.deviceProfileName"
              },
              "transforms": [
                {
                  "code": "\treturn \"No downlinks found for device profile {0}, double click to configure profile\".format(self.view.params.deviceProfileName)",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "labels/dark-green-header",
            "marginLeft": "3%",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "newTab": true,
            "page": "/device-profile/{view.params.deviceProfileID}"
          },
          "scope": "C",
          "type": "nav"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "classes": "pageFormat/grey-bubble"
      }
    },
    "type": "ia.container.flex"
  }
}