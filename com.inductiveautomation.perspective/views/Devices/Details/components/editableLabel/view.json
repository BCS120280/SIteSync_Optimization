{
  "custom": {},
  "params": {
    "componentValue": "my content",
    "isEditing": true,
    "labelText": "value"
  },
  "propConfig": {
    "params.componentValue": {
      "paramDirection": "inout",
      "persistent": true
    },
    "params.isEditing": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.labelText": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 78
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "200px"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.labelText"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "classes": "label"
          }
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "path": "view.params.isEditing"
                  },
                  "transforms": [
                    {
                      "code": "\tif value:\n\t\treturn False\n\telse:\n\t\treturn True",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.componentValue"
                  },
                  "overlayOptOut": true,
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "TextField"
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "path": "view.params.isEditing"
                  },
                  "type": "property"
                }
              },
              "props.text": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "view.params.componentValue"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.input.text-field"
          }
        ],
        "meta": {
          "name": "content"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "justify": "space-around"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.flex"
  }
}