                      },
                      "props.value": {
                        "onChange": {
                          "enabled": null,
                          "script": "\tif currentValue.value !\u003d None:\n\t\tself.parent.parent.getChild(\"Dropdown\").props.options \u003d currentValue.value\n\telse:\n\t\tself.parent.parent.getChild(\"Dropdown\").props.options \u003d self.view.custom.models"
