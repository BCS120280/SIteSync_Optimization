          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "basis": "50px"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.devEUI"
                  },
                  "transforms": [
                    {
                      "code": "\treturn \"{0} - {1}\".format(self.view.params.deviceName, value)",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "labels/dark-green-header"
