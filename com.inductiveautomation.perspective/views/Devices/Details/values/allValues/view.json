{
  "custom": {},
  "params": {
    "tagPath": "[default]aloxyCoreTest"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "meta": {
          "name": "FlexRepeater"
        },
        "propConfig": {
