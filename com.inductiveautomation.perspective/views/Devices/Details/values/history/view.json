{
  "custom": {},
  "params": {
    "tagPath": "[default]VoBo 6X Westlake/data/Battery"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 100,
      "width": 250
    }
  },
  "root": {
    "children": [
      {
        "meta": {
          "name": "Sparkline"
        },
        "position": {
          "basis": "96px",
          "shrink": 0
        },
        "propConfig": {
          "props.points": {
            "binding": {
              "config": {
                "avoidScanClassValidation": true,
                "dateRange": {
                  "mostRecent": "1",
                  "mostRecentUnits": "WEEK"
                },
                "enableValueCache": true,
                "ignoreBadQuality": false,
                "polling": {
                  "enabled": false,
                  "rate": "30"
                },
                "preventInterpolation": false,
                "returnFormat": "Wide",
                "returnSize": {
                  "type": "RAW"
                },
                "tags": "{parent.custom.historyKey}",
                "valueFormat": "DOCUMENT"
              },
              "transforms": [
                {
                  "code": "\titems \u003d []\n\tfor i in value:\n\t\titems.append(i[\u0027value\u0027])\n\treturn items",
                  "type": "script"
                }
              ],
              "type": "tag-history"
            }
          }
        },
        "type": "ia.display.sparkline"
      }
    ],
    "custom": {
      "historyKey": [
        {
          "aggregate": "Average",
          "alias": "value"
        }
      ]
    },
    "meta": {
      "name": "root"
    },
    "propConfig": {
      "custom.historyKey[0].path": {
        "binding": {
          "config": {
            "path": "view.params.tagPath"
          },
          "type": "property"
        }
      }
    },
    "props": {
      "direction": "column"
    },
    "type": "ia.container.flex"
  }
}