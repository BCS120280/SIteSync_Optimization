{
  "custom": {},
  "params": {
    "tagPath": "[default]VoBo 6X Westlake/data/Battery"
  },
  "propConfig": {
    "params.tagPath": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 200,
      "width": 384
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.tagPath"
                  },
                  "transforms": [
                    {
                      "code": "\ttry:\n\t\ttagName \u003d value.split(\u0027/\u0027)[-1]\n\t\tif tagName \u003d\u003d \u0027valueToDisplay\u0027:\n\t\t\treferenceName \u003d system.tag.readBlocking([value + \".SourceTagPath\"])[0].value\n\t\t\tif referenceName !\u003d None and  referenceName !\u003d \"\":\n\t\t\t\tref \u003d referenceName.split(\u0027/\u0027)[-1] + \":\"\n\t\t\telse:\n\t\t\t\tref \u003d \"Primary Value not configured for this device type, pick one on the device profile\"\n\t\t\treturn ref\n\t\telse:\n\t\t\t\n\t\t\treturn tagName  + \":\"\n\texcept Exception as e:\n\t\treturn value",
                      "type": "script"
                    }
                  ],
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "label"
              },
              "textStyle": {
                "textTransform": "capitalize"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}"
                  },
                  "transforms": [
                    {
                      "code": "\tif quality.badOrError:\n\t\treturn \"Error loading value\"\n\telse:\n\t\t\n\t\treturn value",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              }
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_1"
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}.engUnit"
                  },
                  "transforms": [
                    {
                      "code": "\tif quality.badOrError:\n\t\treturn \"Error loading engineering unit\"\n\telse:\n\t\t\n\t\treturn value",
                      "type": "script"
                    }
                  ],
                  "type": "tag"
                }
              }
            },
            "props": {
              "style": {
                "marginLeft": "1%"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer_0"
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "trend"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "position.display": {
                "binding": {
                  "config": {
                    "path": "parent.custom.isTrendable"
                  },
                  "type": "property"
                }
              },
              "props.params.tagPath": {
                "binding": {
                  "config": {
                    "path": "view.params.tagPath"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "path": "Devices/Details/values/history",
              "style": {
                "backgroundColor": "white",
                "borderBottomLeftRadius": "12px",
                "borderBottomRightRadius": "12px",
                "borderStyle": "none",
                "borderTopLeftRadius": "12px",
                "borderTopRightRadius": "12px"
              },
              "useDefaultViewHeight": true,
              "useDefaultViewWidth": true
            },
            "type": "ia.display.view"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.sendMessage(\"trend\", payload\u003d{\"tagPath\":self.view.params.tagPath})"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "30px"
            },
            "propConfig": {
              "custom.isHistoryEnabled": {
                "binding": {
                  "config": {
                    "fallbackDelay": 2.5,
                    "mode": "indirect",
                    "references": {
                      "tagPath": "{view.params.tagPath}"
                    },
                    "tagPath": "{tagPath}.historyEnabled"
                  },
                  "type": "tag"
                }
              }
            },
            "props": {
              "color": "teal",
              "path": "material/trending_up"
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "values",
          "tooltip": {
            "enabled": true,
            "text": "trended values"
          }
        },
        "position": {
          "grow": 1,
          "shrink": 0
        },
        "propConfig": {
          "custom.isTrendable": {
            "binding": {
              "config": {
                "fallbackDelay": 2.5,
                "mode": "indirect",
                "references": {
                  "tagPath": "{view.params.tagPath}"
                },
                "tagPath": "{tagPath}.dataType"
              },
              "transforms": [
                {
                  "code": "\tif \"int\" in str(value).lower() or \"float\" in str(value).lower():\n\t\treturn True\n\telse:\n\t\treturn False",
                  "type": "script"
                }
              ],
              "type": "tag"
            }
          },
          "position.display": {
            "binding": {
              "config": {
                "path": "./Icon.custom.isHistoryEnabled"
              },
              "type": "property"
            }
          }
        },
        "props": {
          "justify": "flex-end"
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignContent": "space-around",
      "justify": "space-between",
      "style": {
        "classes": "pageFormat/grey-bubble"
      },
      "wrap": "wrap"
    },
    "type": "ia.container.flex"
  }
}