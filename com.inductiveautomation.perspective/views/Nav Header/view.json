{
  "custom": {},
  "events": {
    "system": {
      "onStartup": [
        {
          "config": {
            "script": "\tostype \u003d self.session.props.device.type\n\tenableData \u003d False;\n\tif(ostype \u003d\u003d \"designer\"):\n\t\tenableData \u003d True;\n\telif(ostype \u003d\u003d \"browser\"):\n\t\tenableData \u003d True;\n\telif(ostype \u003d\u003d \"ios\"):\n\t\tenableData \u003d False;\n\telif(ostype \u003d\u003d \"android\"):\n\t\tenableData \u003d False;\n\telif(ostype \u003d\u003d \"workstation\"):\n\t\tenableData \u003d True;\n\t\t\n\tself.session.custom.enableDataPage \u003d enableData;"
          },
          "scope": "G",
          "type": "script"
        },
        {
          "config": {
            "script": "\t\n\tuser_roles \u003d self.session.props.auth.user.roles\n\n\tmatches \u003d []\n\timport json\n\tfor role in user_roles:\n\n\t\ttenant \u003d system.sitesync.findTenantByRole(str(role))\n\t\t\n\t\tif tenant \u003d\u003d \u0027null\u0027:\n\t\t\tsystem.perspective.print(\"skip \" + role)\n\t\telse:\n\t\t\tsystem.perspective.print(\"MATCH \" + role)\n\t\t\tmatches.append(json.loads(tenant))\n\t\n\tif len(matches) \u003d\u003d 1:\n\t\tsystem.perspective.print(\"matched tenant with id: \" + matches[0][\u0027id\u0027])\n\t\tlogger.info(\"matched tenant with id: \" + matches[0][\u0027id\u0027])\n\t\tlogger.info(matches)\n\telif len(matches) \u003e 1:\n\t\tsystem.perspective.print(\"more than one matching tenant\")\n\t\tsystem.perspective.print(len(matches))\n\t\tsystem.perspective.print(matches)\n\t\tsystem.perspective.navigate(view\u003d\"Enterprise/Tenant/tenant-select1\", params\u003d{\"matches\":matches})\n\n\telse:\n\n\t\tsystem.perspective.print(\"Signed in user does not belong to a matching tenant.\")\n\t\tlogger.error(\"Failed to place user into tenant. Verify tenant name matches a role in your identity provider.\")\n\t\tsystem.perspective.navigate(page\u003d\"/notAuth\")"
          },
          "enabled": false,
          "scope": "G",
          "type": "script"
        }
      ]
    }
  },
  "params": {},
  "props": {
    "defaultSize": {
      "height": 74,
      "width": 1151
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "page": "/"
                  },
                  "scope": "C",
                  "type": "nav"
                }
              }
            },
            "meta": {
              "name": "greensync5crop"
            },
            "position": {
              "grow": 1
            },
            "propConfig": {
              "props.source": {
                "binding": {
                  "config": {
                    "expression": "{session.props.gateway.address} + \"/res/hce/syncimages/greensync5crop.png\""
                  },
                  "type": "expr"
                }
              }
            },
            "props": {
              "style": {
                "classes": "hand-on-hover"
              }
            },
            "type": "ia.display.image"
          },
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "session.custom.SiteName"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "style": {
                "classes": "labels/dark-green-header"
              }
            },
            "type": "ia.display.label"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "shrink": 0
        },
        "props": {
          "direction": "column",
          "wrap": "wrap"
        },
        "type": "ia.container.flex"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tif self.session.custom.enableDataPage:\n\t\tsystem.perspective.navigate(page\u003d\"/device-management\")\n\telse:\n\t\tsystem.perspective.navigate(page\u003d\"/mobileDeviceList\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "devices headerg4"
        },
        "position": {
          "basis": "108px"
        },
        "propConfig": {
          "props.source": {
            "binding": {
              "config": {
                "expression": "{session.props.gateway.address} + \"/res/hce/syncimages/devices-headerg4.png\""
              },
              "type": "expr"
            }
          }
        },
        "props": {
          "style": {
            "classes": "hand-on-hover"
          }
        },
        "type": "ia.display.image"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "page": "/dashboard"
              },
              "scope": "C",
              "type": "nav"
            }
          }
        },
        "meta": {
          "name": "dataheaderg5"
        },
        "position": {
          "basis": "108px"
        },
        "propConfig": {
          "props.source": {
            "binding": {
              "config": {
                "expression": "{session.props.gateway.address} + \"/res/hce/syncimages/dataheaderg4.png\""
              },
              "enabled": false,
              "type": "expr"
            }
          }
        },
        "props": {
          "source": "data:image/png;base64,\u003d",
          "style": {
            "classes": "hand-on-hover"
          }
        },
        "type": "ia.display.image"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "alignItems": "center",
      "justify": "space-around",
      "style": {
        "backgroundColor": "#D5D5D5"
      }
    },
    "type": "ia.container.flex"
  }
}