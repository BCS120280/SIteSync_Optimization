{
  "custom": {},
  "params": {
    "tenantID": 1,
    "tenantName": "value"
  },
  "propConfig": {
    "params.tenantID": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tenantName": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {},
  "root": {
    "children": [
      {
        "meta": {
          "name": "Label_0"
        },
        "propConfig": {
          "props.text": {
            "binding": {
              "config": {
                "path": "view.params.tenantName"
              },
              "transforms": [
                {
                  "code": "\treturn \"Are you sure you want to delete \" + value + \"?\"",
                  "type": "script"
                }
              ],
              "type": "property"
            }
          }
        },
        "props": {
          "style": {
            "fontSize": "X-Large",
            "fontWeight": "bold",
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "basis": "32px"
        },
        "props": {
          "style": {
            "textAlign": "center"
          },
          "text": "Deleting will make all devices unaccessible, you cannot undo this action."
        },
        "type": "ia.display.label"
      },
      {
        "children": [
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\tsystem.perspective.closePopup(\"\")"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "cancel"
            },
            "props": {
              "image": {
                "icon": {
                  "path": "material/block"
                }
              },
              "style": {
                "backgroundColor": "#17000042"
              },
              "text": "Cancel"
            },
            "type": "ia.input.button"
          },
          {
            "events": {
              "dom": {
                "onClick": {
                  "config": {
                    "script": "\timport json\n\ttry:\n\t\tresults \u003d system.sitesync.removeTenant(int(self.view.params.tenantID))\n\t\tif results !\u003d None:\n\t\t\tsystem.perspective.print(results)\n\t\t\tresults \u003d json.loads(results)\n\t\t\t\n\t\t\tif utils.resultParser.isResultSuccess(results):\n\t\t\t\tsystem.perspective.closePopup(\"\")\n\t\t\t\tsystem.perspective.navigate(page\u003d\"/tenant-management\")\n\t\t\telse:\n\t\t\t\tsystem.perspective.closePopup(\"\")\n\t\t\t\tutils.messages.errors.showErrorMessage(utils.resultParser.getResultMessage(results))\n\texcept Exception as e:\n\t\tsystem.perspective.print(\"Error deleting tenant: \" + str(e))\n\t\tsystem.perspective.closePopup(\"\")\n\t\tutils.resultParser.getResultMessage(\"Error deleting tenant: \" + str(e))"
                  },
                  "scope": "G",
                  "type": "script"
                }
              }
            },
            "meta": {
              "name": "deletebtn"
            },
            "props": {
              "image": {
                "icon": {
                  "path": "material/delete_forever"
                }
              },
              "style": {
                "classes": "diagnostics/buttons/error"
              },
              "text": "Delete Forever"
            },
            "type": "ia.input.button"
          }
        ],
        "meta": {
          "name": "FlexContainer"
        },
        "props": {
          "justify": "space-evenly",
          "style": {
            "padding": "3%"
          }
        },
        "type": "ia.container.flex"
      }
    ],
    "meta": {
      "name": "root"
    },
    "props": {
      "direction": "column",
      "justify": "space-around"
    },
    "type": "ia.container.flex"
  }
}