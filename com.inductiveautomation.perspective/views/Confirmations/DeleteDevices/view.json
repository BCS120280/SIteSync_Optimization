            "onClick": {
              "config": {
                "script": "\ttry:\n\t\tsystem.perspective.print(\"Deleting database device...\" + self.view.params.devEUI)\n\t\timport json\n\t\tfor devEUI in self.view.params.devEUI:\n\t\t\tresults \u003d json.loads(system.sitesync.deleteDevice(devEUI))\n\t\t\tsystem.perspective.print(str(results))\n\t\t\tif utils.resultParser.isResultSuccess(results):\n\t\t\t\tsystem.tag.deleteTags([self.view.params.fullTagPath])\n\t\t\t\n\t\t\t\t\n\t\t\telse:\n\t\t\t\tutils.messages.errors.showErrorMessage(utils.resultParser.getResultMessage(results))\n\t\tsystem.perspective.closePopup(\"h8PEVgyR\")\t\n\t\tsystem.perspective.sendMessage(\"afterDelete\", {})\n\texcept Exception as e:\n\t\tsystem.perspective.closePopup(\"h8PEVgyR\")\n\t\tutils.messages.errors.showErrorMessage(str(e))"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
