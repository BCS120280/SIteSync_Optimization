{
  "custom": {},
  "params": {
    "status": []
  },
  "propConfig": {
    "params.status": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 612,
      "width": 680
    }
  },
  "root": {
    "children": [
      {
        "events": {
          "system": {
            "onStartup": {
              "config": {
                "script": "\timport json\n\tself.props.data \u003d json.loads(self.session.custom.bulkStatus)"
              },
              "enabled": false,
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Table"
        },
        "position": {
          "breakpoints": [
            {
              "colIndex": 1,
              "name": "sm",
              "order": 1,
              "rowIndex": 1,
              "span": 10
            },
            {
              "colIndex": 1,
              "name": "md",
              "order": 0,
              "rowIndex": 1,
              "span": 10
            },
            {
              "colIndex": 1,
              "name": "lg",
              "order": 1,
              "rowIndex": 1,
              "span": 10
            }
          ],
          "height": 471
        },
        "propConfig": {
          "props.data": {
            "binding": {
              "config": {
                "path": "view.params.status"
              },
              "type": "property"
            }
          }
        },
        "type": "ia.display.table"
      },
      {
        "meta": {
          "name": "Label"
        },
        "position": {
          "breakpoints": [
            {
              "colIndex": 3,
              "name": "sm",
              "order": 0,
              "rowIndex": 0,
              "span": 6
            },
            {
              "colIndex": 3,
              "name": "md",
              "order": 0,
              "rowIndex": 0,
              "span": 6
            },
            {
              "colIndex": 3,
              "name": "lg",
              "order": 0,
              "rowIndex": 0,
              "span": 6
            }
          ],
          "height": 60
        },
        "props": {
          "style": {
            "color": "#0D5C63",
            "fontWeight": "bolder"
          },
          "text": "Bulk Upload Results",
          "textStyle": {
            "fontSize": 20,
            "textAlign": "center"
          }
        },
        "type": "ia.display.label"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\ttry:\n\t\ttable \u003d self.getSibling(\"Table\").props.data\n\t\theaders \u003d []\n\t\trows \u003d []\n\t\tfor r in table:\n\t\t\trow \u003d r.values()\n\t\t\trows.append(row)\n\t\theaders \u003d r.keys()\n\t\t\n\t\tcsv \u003d system.dataset.toDataSet(headers, rows)\n\t\tsystem.perspective.print(csv)\n\t\tdata \u003d system.dataset.toExcel(True, [csv])\n\t\tnow \u003d system.date.now()\n\t\tformattedDate \u003d system.date.format(now,\"MM-dd-yyyhmms\")\n\t\tfileName \u003d formattedDate + \"_bulkUploadResults.xlsx\"\n\t\tsystem.perspective.download(fileName,data)\n\texcept Exception as e:\n\t\tsystem.perspective.print(e)"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "Icon",
          "tooltip": {
            "enabled": true,
            "text": "Click to download results"
          }
        },
        "position": {
          "breakpoints": [
            {
              "colIndex": 9,
              "name": "sm",
              "order": 1,
              "rowIndex": 0,
              "span": 1
            },
            {
              "colIndex": 9,
              "name": "md",
              "order": 1,
              "rowIndex": 0,
              "span": 1
            },
            {
              "colIndex": 9,
              "name": "lg",
              "order": 1,
              "rowIndex": 0,
              "span": 1
            }
          ],
          "height": 60
        },
        "props": {
          "path": "material/cloud_download"
        },
        "type": "ia.display.icon"
      }
    ],
    "meta": {
      "name": "root"
    },
    "type": "ia.container.column"
  }
}