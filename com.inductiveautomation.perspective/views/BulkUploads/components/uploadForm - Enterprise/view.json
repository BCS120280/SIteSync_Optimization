      {
        "events": {
          "component": {
            "onFileReceived": {
              "config": {
                "script": "\ttry:\n\t\timport csv\n\t\tfrom io import StringIO\n\t\tfrom org.python.core.util import StringUtil\n\t\tfileContents \u003d  event.file.getString(\"UTF-8\")\n\t\tdata \u003d event.file.getBytes()\n\t\treader \u003d csv.DictReader(StringIO(StringUtil.fromBytes(data)))\n\t\titems \u003d []\n\t\tfor row in reader:\n\t\t\tr \u003d {key: value.decode(\"utf-8\") for key, value in row.items()}\n\t\t\titems.append(r)\n\t\t\t\n\t\tself.parent.custom.parsedFile \u003d items\n\texcept Exception as e:\n\t\tsystem.perspective.print(str(e))"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "FileUpload"
        },
        "position": {
          "basis": "145px"
        },
        "props": {
          "fileUploadIcon": {
            "style": {
              "marginTop": "2%"
            }
          },
          "maxUploads": 1,
          "supportedFileTypes": [
            "csv"
          ]
        },
        "type": "ia.input.fileupload"
      },
      {
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\t\t\n\tdef getValue(valueList, idToSearchFor):\n\t\tfor v in valueList:\n\t\t\tif v[\u0027value\u0027] \u003d\u003d idToSearchFor:\n\t\t\t\treturn v[\u0027label\u0027]\n\t\treturn \"Not found\"\n\ttry:\n\t\tsystem.perspective.print(\"Starting validation\")\n\t\tself.parent.getChild(\"FlexContainer_0\").getChild(\"errors\").position.display \u003d False\n\t\tself.position.display \u003d False\n\t\t## validate form, \n\t\tvalid \u003d False\n\t\ttenantSelected \u003d False\n\t\tappSelected \u003d False\n\t\tfileUploaded \u003d False\n\t\tuseCaseSelected \u003d False\n\t\tmodelSelected \u003d False\n\t\tappName \u003d \"\"\n\t\tmessage \u003d \"\"\n\t\tself.parent.getChild(\"FlexContainer_0\").getChild(\"errors\").props.text \u003d message\n\t\tselectedTenant \u003d self.parent.custom.tenant\n\t\t\n\t\t\t\n\t\tsystem.perspective.print(\"Starting validation model\")\n\t\tif self.parent.custom.selectedModelID !\u003d None and self.parent.custom.selectedModelID \u003e -1:\n\t\t\tmodelSelected \u003d True\n\t\telse:\n\t\t\tmessage \u003d \"Select a Device type\"\n\t\tsystem.perspective.print(\"Starting validation - use case\")\n\t\tif self.parent.custom.useCase !\u003d None and self.parent.custom.useCase !\u003d -1:\n\t\t\tuseCaseSelected \u003d True \n\t\telse:\n\t\t\tself.parent.custom.useCase \u003d \"\"\n\t\t\t\n\t\tif self.parent.custom.tenant !\u003d None and self.parent.custom.tenant !\u003d -1:\n\t\t\ttenantSelected \u003d True \n\t\telse:\n\t\t\tmessage \u003d \"Select a tenant to own these devices\"\n\t\t\t\n\t\tsystem.perspective.print(\"Starting validation app\")\n\t\t\n\t\t\t\n\t\tsystem.perspective.print(\"Starting validation - parsed file\")\n\t\tif self.parent.custom.parsedFile !\u003d None:\n\t\t\tif len(self.parent.custom.parsedFile) \u003e 0:\n\t\t\t\tfileUploaded \u003d True\n\t\t\t\t\n\t\t\telse:\n\t\t\t\tmessage \u003d \"Empty file uploaded, ensure at least 1 device is in file.\"\n\t\telse:\n\t\t\tmessage \u003d \"Please upload file\"\n\t\t\n\t\tsystem.perspective.print(\"completed validation\")\n\t\t\n\t\tif fileUploaded and modelSelected:\n\t\t\tsystem.perspective.print(\"valid\")\n\t\t\tvalid \u003d True\n\t\tsystem.perspective.print(message)\n\t\tself.parent.getChild(\"FlexContainer_0\").getChild(\"errors\").props.text \u003d message\n\t\tself.parent.getChild(\"FlexContainer_0\").getChild(\"errors\").position.display \u003d True\n\t\tif valid:\n\t\t\tp \u003d {\"rows\":self.parent.custom.parsedFile, \n\t\t\t\u0027tenantName\u0027:  \"standard\",\n\t\t\t\u0027tenantID\u0027:selectedTenant,\n\t\t\t\u0027deviceProfileID\u0027:self.parent.custom.selectedModelID,\n\t\t\t\u0027deviceProfileList\u0027: self.parent.custom.models,\n\t\t\t\u0027selectedUseCase\u0027:self.parent.custom.useCase,\n\t\t\t\u0027selectedAppID\u0027:self.parent.custom.appID, \n\t\t\t\"selectedApp\":\"\", \n\t\t\t\"tagProvider\":self.parent.custom.tagProvider\n\t\t\t\n\t\t\t}\n\t\t\tsystem.perspective.sendMessage(\"processFile\", payload\u003dp)\n\t\telse:\n\t\t\tsystem.perspective.print(\"not valid\")\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\t\t\n\t\tself.position.display \u003d True\n\texcept Exception as e:\n\t\tsystem.perspective.print(str(e))\n\t\tself.position.display \u003d True"
              },
              "scope": "G",
              "type": "script"
            }
          }
