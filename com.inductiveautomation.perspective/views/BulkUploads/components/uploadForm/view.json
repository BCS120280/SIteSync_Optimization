              "display": false,
              "grow": 1,
              "shrink": 0
            },
            "propConfig": {
              "props.options": {
                "binding": {
                  "config": {
                    "path": "/root.custom.tagProviders"
                  },
                  "type": "property"
                }
              },
              "props.value": {
                "binding": {
                  "config": {
                    "bidirectional": true,
                    "path": "/root.custom.tagProvider"
                  },
                  "type": "property"
                }
              }
            },
            "props": {
              "placeholder": {
                "text": "--TAG PROVIDER--"
              }
            },
            "type": "ia.input.dropdown"
          },
          {
            "children": [
              {
                "meta": {
                  "name": "Dropdown"
                },
                "position": {
                  "grow": 1
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "path": "..../tagPath.custom.normalized"
                      },
                      "type": "property"
                    }
                  },
                  "props.options": {
                    "binding": {
                      "config": {
                        "path": "/root.custom.tagPaths"
                      },
                      "transforms": [
                        {
                          "code": "\toptions \u003d []\n\tfor t in value:\n\t\toptions.append({\"label\":t[\u0027tagPathBase\u0027], \"value\":t[\u0027tagPathBase\u0027]})\n\treturn options",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  },
                  "props.value": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "/root.custom.useCase"
                      },
                      "type": "property"
                    }
                  }
                },
                "props": {
                  "placeholder": {
                    "text": "--TAG PATH--"
                  },
                  "showClearIcon": true
                },
                "type": "ia.input.dropdown"
              },
              {
                "meta": {
                  "name": "TextField"
                },
                "propConfig": {
                  "position.display": {
                    "binding": {
                      "config": {
                        "path": "..../tagPath.custom.normalized"
                      },
                      "transforms": [
                        {
                          "code": "\treturn not value",
                          "type": "script"
                        }
                      ],
                      "type": "property"
                    }
                  },
                  "props.text": {
                    "binding": {
                      "config": {
                        "bidirectional": true,
                        "path": "/root.custom.useCase"
                      },
                      "type": "property"
                    }
                  }
                },
                "type": "ia.input.text-field"
              }
            ],
