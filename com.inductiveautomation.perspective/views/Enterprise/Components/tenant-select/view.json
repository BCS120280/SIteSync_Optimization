{
  "custom": {},
  "params": {
    "id": "value",
    "tenantName": "value"
  },
  "propConfig": {
    "params.id": {
      "paramDirection": "input",
      "persistent": true
    },
    "params.tenantName": {
      "paramDirection": "input",
      "persistent": true
    }
  },
  "props": {
    "defaultSize": {
      "height": 72,
      "width": 384
    }
  },
  "root": {
    "children": [
      {
        "children": [
          {
            "meta": {
              "name": "Label"
            },
            "position": {
              "display": false,
              "shrink": 0
            },
            "props": {
              "text": "Tenant Name:"
            },
            "type": "ia.display.label"
          },
          {
            "meta": {
              "name": "Label_0"
            },
            "position": {
              "shrink": 0
            },
            "propConfig": {
              "props.text": {
                "binding": {
                  "config": {
                    "path": "view.params.tenantName"
                  },
                  "type": "property"
                }
              }
            },
            "type": "ia.display.label"
          }
        ],
        "events": {
          "dom": {
            "onClick": {
              "config": {
                "script": "\tself.session.custom.tenantID \u003d self.view.params.id\n\tself.session.custom.SiteName \u003d self.view.params.tenantName\n\tsystem.perspective.navigate(page\u003d\"/device-management\")"
              },
              "scope": "G",
              "type": "script"
            }
          }
        },
        "meta": {
          "name": "FlexContainer"
        },
        "position": {
          "grow": 1
        },
        "props": {
          "alignItems": "center"
        },
        "type": "ia.container.flex"
      },
      {
        "children": [
          {
            "meta": {
              "name": "Icon"
            },
            "position": {
              "basis": "30px"
            },
            "props": {
              "path": "material/chevron_right"
            },
            "type": "ia.display.icon"
          }
        ],
        "meta": {
          "name": "FlexContainer_0"
        },
        "position": {
          "basis": "96px"
        },
        "props": {
          "alignItems": "flex-end",
          "direction": "column",
          "justify": "center"
        },
        "type": "ia.container.flex"
      }
    ],
    "events": {
      "dom": {
        "onClick": {
          "config": {
            "script": "\tself.session.custom.tenantID \u003dself.view.params.id\n\tself.session.custom.SiteName \u003d self.view.params.tenantName\n\tsystem.perspective.navigate(page\u003d\"/device-management\")"
          },
          "scope": "G",
          "type": "script"
        }
      }
    },
    "meta": {
      "name": "root"
    },
    "props": {
      "style": {
        "backgroundColor": "#80808057",
        "borderBottomLeftRadius": "12px",
        "borderBottomRightRadius": "12px",
        "borderTopLeftRadius": "12px",
        "borderTopRightRadius": "12px",
        "fontSize": "large",
        "fontWeight": "bold",
        "margin": "2%",
        "padding": "1%"
      }
    },
    "type": "ia.container.flex"
  }
}