{"onPageStartup":"\tsystem.perspective.openDock('11')","onBarcodeDataReceived":"\tlogger = system.util.getLogger('SiteSyncQrScan')\n\t\t\t\n\tpayloadData = {\n\t\"scanValue\" : data[\"text\"]\n\t}\n\tlogger.debug('Payload: ' + str(payloadData))\n\t\n\tsystem.perspective.sendMessage(messageType = session.custom.barcodeEvent, payload = payloadData, scope = 'session')","onBluetoothReceived":"\t","onAccelerometerDataReceived":"\t","onNdefDataReceived":"\t"}