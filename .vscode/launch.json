    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: Current File",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        },
        {
            "name": "Jython 2.7 Debug",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "JYTHONPATH": "${workspaceFolder}",
                "PYTHONPATH": "${workspaceFolder}"
            },
            "args": [ ]
        },
        {
            "name": "Jython 2.7 Interactive",
            "type": "node",
            "request": "launch",
            "program": "",
            "console": "integratedTerminal",
            "cwd": "${workspaceFolder}",
            "env": {
                "JYTHONPATH": "${workspaceFolder}",
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "CPython 3 (do NOT use for Ignition scripts)",
            "type": "node",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal"
        }
    ]
}
