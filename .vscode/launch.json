{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Jython 2.7 Debug (Current File)",
            "type": "node-terminal",
            "request": "launch",
            "command": "./jython.sh \"${file}\"",
            "cwd": "${workspaceFolder}",
            "env": {
                "JYTHONPATH": "${workspaceFolder}",
                "PYTHONPATH": "${workspaceFolder}"
            }
        },
        {
            "name": "Jython 2.7 Interactive",
            "type": "node-terminal",
            "request": "launch",
            "command": "./jython.sh",
            "cwd": "${workspaceFolder}",
            "env": {
                "JYTHONPATH": "${workspaceFolder}",
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
