{
    "[python]": {
        "editor.insertSpaces": false,
        "editor.tabSize": 4
    },
    "files.watcherExclude": {
        "**/.ignition-stubs/**": true
    },
    "python.analysis.exclude": [
        "**/.ignition-stubs/**"
    ],
    "python.analysis.ignore": [
        "**/.ignition-stubs/**"
    ],
    "ignition.diagnostics.enabled": false,
    "chat.mcp.serverSampling": {
        "SIteSync_Optimization/.vscode/mcp.json: io.github.upstash/context7": {
            "allowedModels": [
                "copilot/auto",
                "claude-code/claude-haiku-4.5",
                "copilotcli/claude-haiku-4.5",
                "copilot/claude-haiku-4.5"
            ]
        },
        "SIteSync_Optimization/.vscode/mcp.json: ignition-mcp": {
            "allowedModels": [
                "copilot/auto",
                "claude-code/claude-haiku-4.5",
                "copilotcli/claude-haiku-4.5",
                "copilot/claude-haiku-4.5"
            ]
        }
    },
    "claudeCode.initialPermissionMode": "plan",
    "cSpell.ignorePaths": [
        "**/*.md"
    ],
    "cSpell.words": [
        "Jython",
        "Ignition",
        "Cirrus",
        "CirrusLink",
        "UDT",
        "toMillis",
        "toInstant",
        "jsonEncode",
        "DropReason",
        "ConfigError",
        "PublishError"
    ]
}